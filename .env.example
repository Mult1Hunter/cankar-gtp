# Copy to .env and fill in. Never commit .env.

# Claude API — used from Phase 5 (synthetic pair generation)
ANTHROPIC_API_KEY=

# Hugging Face — dataset/checkpoint sync (write token)
HF_TOKEN=

# RunPod — cloud training (Phase 3+)
RUNPOD_API_KEY=

# Weights & Biases — optional training telemetry
WANDB_API_KEY=

# Cloudflare R2 — optional alternative artifact store
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
